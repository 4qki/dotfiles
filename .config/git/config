[user]
	name = 4qki
	email = max-rodriguez@tuta.io
	signingkey = /home/max/.ssh/id_ed25519
[init]
	defaultBranch = main
[pull]
	rebase = true
[core]
	editor = nvim --clean
	excludesfile = $HOME/.gitignore_global
[commit]
	gpgsign = true
[url "ssh://git@github.com/"]
    insteadOf = https://github.com/

[alias]
	st = status
	cm = commit -m
	p = push
	pf = push --force-with-lease
	wa = worktree add
	wl = worktree list
	wd = worktree remove
	pretty = log --pretty=format:'%h %ad | %s%d [%an]' --graph --date=short
[gpg]
	format = ssh
