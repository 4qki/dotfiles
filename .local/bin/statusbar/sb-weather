#!/bin/bash

# Define location explicitly
LOCATION="Orlando"

# Get weather data from wttr.in
weather_data=$(curl -s "wttr.in/$LOCATION?format=%C+%t")

# Extract weather condition (handles multi-word conditions like "Light rain")
condition=$(echo "$weather_data" | awk -F ' +' '{for (i=1; i<=NF-1; i++) printf $i " "; print ""}' | sed 's/ $//')

# Extract temperature (last field)
temperature=$(echo "$weather_data" | awk '{print $NF}')

# Get current hour (24-hour format)
hour=$(date +%H)

# Determine if it's day or night (assuming 6:00-18:00 is daytime)
if (( hour >= 6 && hour < 18 )); then
    DAYTIME=true
else
    DAYTIME=false
fi

# Select Nerd Font weather icon based on condition and time of day
case "$condition" in
    "Clear"|"Sunny")
        if $DAYTIME; then icon="¯îì"  # Sunny
        else icon="¯ì░"  # Clear Night
        fi
        ;;
    "Partly cloudy")
        if $DAYTIME; then icon="¯îé"  # Partly Cloudy (Day)
        else icon="¯ì╣"  # Partly Cloudy (Night)
        fi
        ;;
    "Cloudy") icon="¯îÆ" ;;  # Cloudy
    "Overcast") icon="¯îé" ;;  # Overcast
    "Light rain"|"Drizzle") icon="¯îê" ;;  # Light Rain / Drizzle
    "Moderate rain"|"Showers") icon="¯îÿ" ;;  # Moderate Rain / Showers
    "Heavy rain") icon="¯îÖ" ;;  # Heavy Rain
    "Thunderstorm") 
        if $DAYTIME; then icon="¯îØ"  # Thunderstorm (Day)
        else icon="¯ìñ"  # Thunderstorm (Night)
        fi
        ;;
    "Light snow") icon="¯îÜ" ;;  # Light Snow
    "Moderate snow") icon="¯ìí" ;;  # Moderate Snow
    "Heavy snow") icon="¯ìú" ;;  # Heavy Snow
    "Fog"|"Mist") 
        if $DAYTIME; then icon="¯îô"  # Fog (Day)
        else icon="¯ìå"  # Fog (Night)
        fi
        ;;
    "Hail") icon="¯î£" ;;  # Hail
    "Sleet") icon="¯Ä¬" ;;  # Sleet
    "Windy") icon="¯î░" ;;  # Windy
    "Hot") icon="¯î½" ;;  # Hot Weather
    "Cold") icon="¯ì×" ;;  # Cold Weather
    "Tornado") icon="¯ìæ" ;;  # Tornado
    "Hurricane") icon="¯ì¼" ;;  # Hurricane
    *) icon="¯ì░" ;;  # Unknown (Fallback)
esac

# Print weather with icon
echo "$icon  $temperature"
