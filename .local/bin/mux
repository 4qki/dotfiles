#!/bin/sh
# simple shell script for playing music
# NOTE: playlist syntax - ls $(cat $HOME/.muxrc)/foo

MUSIC_DIR="$(cat $HOME/.muxrc)"
PLAYLIST_DIR="$HOME/.local/share/playlists"

# define colors
red='\033[00;31m'
green='\033[00;32m'
yellow='\033[00;33m'
blue='\033[00;34m'
purple='\033[00;35m'
cyan='\033[00;36m'
lightgray='\033[00;37m'
bred='\033[01;31m'
bgreen='\033[01;32m'
byellow='\033[01;33m'
bblue='\033[01;34m'
bcyan='\033[01;36m'

reset='\033[0m'

# if playlist directory is not created, create it.
if [ ! -f "$PLAYLIST_DIR" ]; then
	mkdir -p $PLAYLIST_DIR
fi

# custom commands
list() {
    echo "$(color "$1" "$(find $2 -mindepth 1 -maxdepth 1 -type f -exec basename {} .$3 \;)")"
}

color() {
    echo "${1}$2${reset}"
}

case $1 in "")
    echo "now playing from $MUSIC_DIR"
    mpv --vo=null --video=no --no-video --term-osd-bar --no-resume-playback --loop-playlist=inf $MUSIC_DIR
;;

"h"|"help")
    printf "usage: ${bgreen}mux${reset} ${blue}[COMMAND]${reset}
    ${lightgray}# without any options, mux will just play the playlist in order.${reset}
    ${bgreen}h${reset},  ${cyan}help${reset}             show help
    ${bgreen}s${reset},  ${cyan}shuffle${reset}          shuffle music
    ${bgreen}ap${reset}, ${cyan}add${reset}              create/add songs to playlist
    ${bgreen}p${reset},  ${cyan}playlist${reset}         play selected playlist
    ${bgreen}d${reset},  ${cyan}download${reset}         downloads song/playlist from specified url
    ${bgreen}ls${reset}, ${cyan}list-songs${reset}       lists all songs
    ${bgreen}f${reset},  ${cyan}find${reset}             search and play a specific song using fzf\n
"
;;

"s"|"shuffle")
    echo "now shuffling $MUSIC_DIR"
    mpv --vo=null --no-video --term-osd-bar --no-resume-playback --loop-playlist=inf --shuffle $MUSIC_DIR
;;

"ap"|"add")
    echo "enter playlist name (new or existing):"
    read -r pname
    [ -z "$pname" ] && exit 0

    target_dir="$PLAYLIST_DIR/$pname"
    mkdir -p "$target_dir" 2>/dev/null

    selections=$(find -L "$MUSIC_DIR" -type f \( -name "*.mp3" -o -name "*.flac" -o -name "*.m4a" \) 2>/dev/null | fzf -m --prompt="add to $pname > " --height=60% --border)

    if [ -n "$selections" ]; then
        echo "$selections" | while read -r file; do
            ln -s "$file" "$target_dir/$(basename "$file")" 2>/dev/null
        done
        echo "${bgreen}added to $pname${reset}"
    fi
;;

"p"|"playlist")
    selection=$(ls -d "${PLAYLIST_DIR}"/*/ 2>/dev/null | fzf --prompt="playlist > " --height=40% --border)

    if [ -n "$selection" ]; then
        echo "Now playing: $(basename "$selection")"
        mpv --vo=null --no-video --term-osd-bar --no-resume-playback --loop-playlist=inf --shuffle "$selection"
    fi
;;

"d"|"download")
    # ensure only urls remain
    shift

    if [ -z "$1" ]; then
        echo "${bred}error:${reset} no url(s) provided"
        echo "usage: ${bgreen}mux${reset} ${cyan}d${reset} [url1] [url2] ..."
        exit 1
    fi

    for url in "$@"; do
        echo "${cyan}downloading:${reset} $url"
        yt-dlp -x --audio-format flac --audio-quality 0 \
               -o "$MUSIC_DIR/%(title)s.%(ext)s" \
               "$url"
    done
    echo "${bgreen}all downloads finished${reset}"
;;

"s"|"shuffle")
    echo "now shuffling $MUSIC_DIR"
    mpv --vo=null --no-video --term-osd-bar --no-resume-playback --loop-playlist=inf --shuffle $MUSIC_DIR
;;

"ls"|"list-songs")
    list "$bgreen" "$MUSIC_DIR" "flac"
;;

"f"|"find")
    selection=$(find -L "$MUSIC_DIR" -type f \( -name "*.mp3" -o -name "*.flac" -o -name "*.m4a" -o -name "*.wav" \) 2>/dev/null | fzf --prompt="select > " --height=40% --layout=reverse --border)

    if [ -n "$selection" ]; then
        echo "now playing $selection"
        mpv --vo=null --no-video --term-osd-bar --no-resume-playback "$selection"
    fi
;;

esac
