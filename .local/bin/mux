#!/bin/sh
# simple shell script for playing music
# NOTE: playlist syntax - ls $(cat $HOME/.muxrc)/foo

musicdir="$(cat $HOME/.muxrc)"
playlistdir="$HOME/.local/share/playlists"

# define colors
red='\033[00;31m'
green='\033[00;32m'
yellow='\033[00;33m'
blue='\033[00;34m'
purple='\033[00;35m'
cyan='\033[00;36m'
lightgray='\033[00;37m'
bred='\033[01;31m'
bgreen='\033[01;32m'
byellow='\033[01;33m'
bblue='\033[01;34m'
bcyan='\033[01;36m'

reset='\033[0m'

# function for music playing
play() {
  clear
  echo "${cyan}now playing: $(basename "$1")${reset}"
  mpv --vo=null --video=no --term-osd-bar --no-resume-playback --loop-playlist=inf "$@"
}

# if playlist directory is not created, create it.
if [ ! -f "$playlistdir" ]; then
  mkdir -p $playlistdir
fi

case $1 in "")
  play $musicdir
  ;;

"s" | "shuffle")
  play $musicdir --shuffle
  ;;

"d" | "download")
  # ensure only urls remain
  shift

  if [ -z "$1" ]; then
    echo "${bred}error:${reset} no url(s) provided"
    echo "usage: ${bgreen}mux${reset} ${cyan}d${reset} [url1] [url2] ..."
    exit 1
  fi

  for url in "$@"; do
    echo "${cyan}downloading:${reset} $url"
    yt-dlp -x --add-metadata --audio-format flac --audio-quality 0 \
      -o "$musicdir/%(title)s.%(ext)s" \
      "$url"
  done
  echo "${bgreen}all downloads finished${reset}"
  ;;

"p" | "playlist")
  list=$(ls -1 "$playlistdir" | fzf --prompt="playlist > ")
  if [ -n "$list" ]; then
    printf "shuffle '$list'? [y/N]: "
    read -r confirm
    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
      play $playlistdir/$list --shuffle
    fi
    play $playlistdir/$list
  fi
  ;;

"ap" | "add")
  printf "playlist name: "
  read -r pname
  [ -z "$pname" ] && exit 0
  mkdir -p "$playlistdir/$pname"
  find "$musicdir" -type f | fzf -m | while read -r f; do
    ln -s "$f" "$playlistdir/$pname/$(basename "$f")" 2>/dev/null
  done
  ;;

"dp" | "del")
  list=$(ls -1 "$playlistdir" | fzf --prompt="delete playlist > ")
  if [ -n "$list" ]; then
    printf "delete '$list'? [y/N]: "
    read -r confirm
    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
      rm -rf "$playlistdir/$list"
      echo "deleted $list."
    fi
  fi
  ;;

"f" | "find")
  song=$(find "$musicdir" -type f | fzf --prompt="find > ")
  [ -n "$song" ] && play "$song"
  ;;

* | "h" | "help")
  printf "usage: ${bgreen}mux${reset} ${blue}[COMMAND]${reset}
    ${lightgray}# without any options, mux will just play the playlist in order.${reset}
    ${bgreen}h${reset},  ${cyan}help${reset}             show help ${bgreen}s${reset},  ${cyan}shuffle${reset}          shuffle music
    ${bgreen}p${reset},  ${cyan}playlist${reset}         play selected playlist
    ${bgreen}d${reset},  ${cyan}download${reset}         downloads song/playlist from specified url
    ${bgreen}ap${reset},  ${cyan}add${reset}         adds a playlist
    ${bgreen}dp${reset},  ${cyan}del${reset}         delete a playlist
    ${bgreen}f${reset},  ${cyan}find${reset}         searches for songs\n
"
  ;;
esac
